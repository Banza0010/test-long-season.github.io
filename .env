# ─── Shopify Storefront API ────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.local`) and fill in your values.
# All VITE_* vars are baked into the build and are PUBLIC. The Storefront token
# is designed to be exposed client-side, so this is safe. Never put an Admin
# API token here.

# Your store domain (NOT the custom domain) — e.g. longseason.myshopify.com
VITE_SHOPIFY_DOMAIN=warehouse.longseason.shop

# Public Storefront API access token
# Shopify Admin → Settings → Apps and sales channels → Develop apps →
#   <your app> → API credentials → Storefront API access token
VITE_SHOPIFY_STOREFRONT_TOKEN=e7b0001c411b305b9c17f42347ce0810

# Storefront API version (optional, defaults to 2026-04)
VITE_SHOPIFY_API_VERSION=2026-04

# Handle of the collection that marks a product as an accessory
# (optional, defaults to "accessories")
VITE_SHOPIFY_ACCESSORIES_HANDLE=accessories

# Metafield that flags archived collections for the Collections page
# (optional, defaults to custom / archived)
VITE_SHOPIFY_ARCHIVED_NAMESPACE=custom
VITE_SHOPIFY_ARCHIVED_KEY=archived

# Leave VITE_SHOPIFY_DOMAIN / VITE_SHOPIFY_STOREFRONT_TOKEN empty to run the
# site on the built-in static demo catalog (no Shopify account needed).
